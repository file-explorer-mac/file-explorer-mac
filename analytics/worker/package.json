{
  "name": "file-explorer-stats-worker",
  "private": true,
  "description": "Serverless ingest + dashboard for File Explorer anonymous usage analytics",
  "scripts": {
    "init-db": "wrangler d1 execute file-explorer-stats --remote --file=./schema.sql",
    "init-db:local": "wrangler d1 execute file-explorer-stats --local --file=./schema.sql",
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "tail": "wrangler tail",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20241106.0",
    "typescript": "^5.7.2",
    "wrangler": "^3.99.0"
  }
}
